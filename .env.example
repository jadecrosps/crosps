# Klaviyo — used by /api/feedback (the /hi QR-code feedback flow)
# Generate the private key in Klaviyo: Account → Settings → API Keys
KLAVIYO_API_KEY=

# ID of the "QR Scanners — Pre-launch" list in Klaviyo
# Find it at: Lists & Segments → your list → URL ends in /list/{id}
KLAVIYO_LIST_ID=

# ── Vercel KV — fallback store for failed Klaviyo submissions ──
# Provisioned automatically when you connect a Vercel KV / Upstash store
# to the project. Pull locally with: vercel env pull .env.local
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Admin endpoint auth ────────────────────────────────────────
# Token required by /api/admin/failed-submissions. Generate with e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value in your local .env and in Vercel project env vars.
ADMIN_API_TOKEN=
